# Example systemd unit for refine-runner. Install at:
#   /etc/systemd/system/refine-runner.service
#
# Prereq: refine has been installed on the host (`pip install /path/to/refine`
# or `pipx install /path/to/refine`). The `refine` command must be on PATH for
# the configured user.
#
# Edit:
#   - User/Group           — operator account (must have run `claude login`)
#   - WorkingDirectory     — the client repo root (where ./refine/refine.toml lives)
#
# refine has zero env-var configuration: refine.toml in WorkingDirectory does it.

[Unit]
Description=refine host runner
After=network.target

[Service]
Type=simple
User=refine
Group=refine
WorkingDirectory=/srv/clients/acme-app
ExecStart=/usr/local/bin/refine runner
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target
